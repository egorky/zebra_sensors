# --- Servidor único (Express + Vite en dev / dist en prod): npm run dev | npm start ---
HOST=0.0.0.0
PORT=5173
# Si nginx (u otro proxy) delante de Node: pon 1 para confiar en X-Forwarded-* (HTTPS, IP real).
# TRUST_PROXY=1
# Opcional: hosts permitidos si en el futuro usas preview de Vite suelto (no el flujo por defecto).
# ALLOWED_HOSTS=mi-dominio.example.com

# --- API Node + base de datos (mismo proceso y puerto; rutas bajo /api) ---
JWT_SECRET=cambia-esto-en-produccion-minimo-32-caracteres
# sqlite (por defecto) | mysql
DATABASE_DRIVER=sqlite
DATABASE_PATH=./server/data/app.db
# Si DATABASE_DRIVER=mysql:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=zebra
# MYSQL_PASSWORD=secret
# MYSQL_DATABASE=zebra_sensors
# Primer usuario si la base está vacía (debe cambiar contraseña al entrar):
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme

# Depuración JSON-RPC hacia Zabbix (consola del proceso Node): URL, método, error Zabbix (token enmascarado).
# ZABBIX_RPC_DEBUG=1

# API Zebra: mismo .env para el proceso Node (poller, etc.) y valores por defecto del cliente (inyectados al compilar con Vite).
# En el navegador puedes sustituirlos guardando en Configuración. En el servidor, estas variables tienen prioridad sobre lo guardado en BD.
ZEBRA_API_BASE_URL=https://api.zebra.com/v2
ZEBRA_API_KEY=tu_api_key_aqui

# Vacío = el navegador llama a /api… en el mismo host y puerto (recomendado).
# Si despliegas el front en otro dominio que el API, pon aquí la URL base del API.
# VITE_BACKEND_URL=
