# --- Desarrollo del front (hot reload: npm run dev) ---
DEV_PORT=5173
DEV_HOST=localhost

# --- Servir la SPA compilada (npm run preview / npm start tras npm run build) ---
HOST=0.0.0.0
PORT=4173
# Opcional: hosts permitidos en la cabecera Host (separados por coma).
# ALLOWED_HOSTS=mi-dominio.example.com

# --- API Zebra por defecto en el cliente (VITE_* se inyectan al compilar) ---
VITE_API_BASE_URL=https://api.zebra.com/v2
VITE_API_KEY=tu_api_key_aqui

# --- API propia Node + SQLite (login JWT, usuarios, snapshots). Obligatorio. ---
VITE_BACKEND_URL=http://localhost:3001
