# --- Servidor único (Express + Vite en dev / dist en prod): npm run dev | npm start ---
HOST=0.0.0.0
PORT=5173
# Opcional: hosts permitidos si en el futuro usas preview de Vite suelto (no el flujo por defecto).
# ALLOWED_HOSTS=mi-dominio.example.com

# --- API Node + SQLite (mismo proceso y puerto; rutas bajo /api) ---
JWT_SECRET=cambia-esto-en-produccion-minimo-32-caracteres
DATABASE_PATH=./server/data/app.db
# Primer usuario si la base está vacía (debe cambiar contraseña al entrar):
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme

# --- Cliente Vite (API Zebra por defecto; backend propio en mismo origen si está vacío) ---
VITE_API_BASE_URL=https://api.zebra.com/v2
VITE_API_KEY=tu_api_key_aqui
# Vacío = el navegador llama a /api… en el mismo host y puerto (recomendado).
# Si despliegas el front en otro dominio que el API, pon aquí la URL base del API.
# VITE_BACKEND_URL=
