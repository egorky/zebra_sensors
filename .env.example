# --- Servidor de desarrollo (Vite: npm run dev) ---
PORT=5173
HOST=localhost

# --- Servidor de producción local / PM2 (Vite preview: npm start) ---
# Tras `npm run build`, `npm start` sirve dist/ usando estos valores:
PREVIEW_HOST=0.0.0.0
PREVIEW_PORT=4173
# Opcional: hosts permitidos separados por coma (cabecero Host). Ejemplo:
# PREVIEW_ALLOWED_HOSTS=mi-dominio.example.com

# --- Configuración de la API de Zebra (valores por defecto en el cliente) ---
VITE_API_BASE_URL=https://api.zebra.com/v2
VITE_API_KEY=tu_api_key_aqui

# --- Credenciales del login de la aplicación web (sin base de datos; se inyectan en el cliente al compilar) ---
# Opción A — un solo administrador:
VITE_APP_USERNAME=admin
VITE_APP_PASSWORD=password

# Opción B — varios usuarios (JSON en UNA línea). Si está definido y es válido, sustituye a la opción A.
# role: "admin" (configuración, enrolado, tareas) u "operator" (solo consulta: inicio, sensores, tareas, logs, alarmas).
# VITE_APP_USERS=[{"username":"admin","password":"cambiar","role":"admin"},{"username":"operador","password":"cambiar","role":"operator"}]
