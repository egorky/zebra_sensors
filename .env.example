# --- Desarrollo del front (hot reload): npm run dev ---
DEV_PORT=5173
DEV_HOST=localhost

# --- Servir la SPA compilada: npm start (junto con el API en el mismo comando) ---
HOST=0.0.0.0
PORT=4173
# Opcional: hosts permitidos en la cabecera Host (separados por coma).
# ALLOWED_HOSTS=mi-dominio.example.com

# --- API Node + SQLite (mismo .env; se arranca con npm run dev / npm start) ---
# No uses la variable PORT para el API: esa es la del servidor Vite que sirve dist/.
BACKEND_PORT=3001
JWT_SECRET=cambia-esto-en-produccion-minimo-32-caracteres
DATABASE_PATH=./server/data/app.db
# Orígenes del navegador permitidos (separados por coma). Por defecto dev (5173) y preview (4173).
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
# Primer usuario si la base está vacía (debe cambiar contraseña al entrar):
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme

# --- Cliente Vite (API Zebra por defecto + URL del backend propio) ---
VITE_API_BASE_URL=https://api.zebra.com/v2
VITE_API_KEY=tu_api_key_aqui
# Debe coincidir con BACKEND_PORT (mismo host/puerto que el API Node).
VITE_BACKEND_URL=http://localhost:3001
