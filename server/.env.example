# Puerto HTTP de la API Node (SQLite). Cambia aquí si 3001 está ocupado; actualiza también VITE_BACKEND_URL en el front.
PORT=3001
JWT_SECRET=cambia-esto-en-produccion-minimo-32-caracteres
DATABASE_PATH=./data/app.db

# Si la tabla de usuarios está vacía al arrancar, se crea UN administrador con estos valores.
# Por defecto usuario "admin" / contraseña "changeme". Ese usuario DEBE cambiar la contraseña al primer login en la app (bloqueo hasta hacerlo).
# En producción define siempre BOOTSTRAP_ADMIN_PASSWORD propio antes del primer arranque.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme

# Origen del front para cabecera CORS (debe coincidir con la URL desde la que abres la SPA, incluido puerto).
CORS_ORIGIN=http://localhost:5173
