{
  "name": "zebra-sensor-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"vite\" \"node server/index.js\"",
    "server:install": "npm install --prefix server",
    "build": "vite build",
    "prestart": "npm run build",
    "start": "concurrently -n web,api -c cyan,magenta \"vite preview\" \"node server/index.js\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed": "node server/scripts/seed.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "lucide-react": "^0.323.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.50.1",
    "react-router-dom": "^6.22.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^13.24.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.10",
    "vite": "^5.1.0"
  }
}
